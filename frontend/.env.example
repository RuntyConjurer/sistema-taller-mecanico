# La API es el origen normal: clientes, citas, órdenes y pagos se guardan en PostgreSQL.
# Use mock únicamente para trabajar deliberadamente sin backend ni persistencia.
VITE_DATA_SOURCE=api

# Vacío usa /api en el mismo origen y el proxy de Vite lo envía a Express.
VITE_API_BASE_URL=
VITE_DEV_API_URL=http://localhost:3100
VITE_DEV_PORT=5180

# Número público para enlaces wa.me, con código de país y solo dígitos.
VITE_WHATSAPP_NUMBER=15556552000
