# Copia este archivo como .env para cambiar el origen de los datos.
#
# mock  (predeterminado): las pantallas usan los datos de src/data/mocks.
#                         No hace falta backend, pero nada se guarda al recargar.
# api                   : las pantallas piden los datos a VITE_API_BASE_URL.
#                         Solo funciona cuando el backend implemente el contrato
#                         documentado en docs/presentacion-frontend.md.
VITE_DATA_SOURCE=mock

# Se ignora mientras VITE_DATA_SOURCE=mock.
VITE_API_BASE_URL=http://localhost:3000
