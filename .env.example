# Copie este archivo como .env. No confirme el .env real en Git.
APP_PORT=8080
POSTGRES_DB=sgtra
POSTGRES_USER=sgtra
POSTGRES_PASSWORD=sgtra_local_password
JWT_SECRET=reemplazar-con-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:8080
TZ=America/Santo_Domingo

# WhatsApp Cloud API. Los secretos se configuran solo en .env local.
WHATSAPP_ENABLED=false
WHATSAPP_APP_ID=identificador-de-la-app
WHATSAPP_APP_SECRET=configurar-localmente
WHATSAPP_ACCESS_TOKEN=configurar-localmente
WHATSAPP_PHONE_NUMBER_ID=identificador-del-numero
WHATSAPP_WABA_ID=identificador-de-la-cuenta
WHATSAPP_BUSINESS_NUMBER=numero-en-formato-internacional
WHATSAPP_TEST_RECIPIENT=destinatario-en-formato-internacional
WHATSAPP_VERIFY_TOKEN=genera-un-valor-aleatorio-largo
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_TEMPLATE_NAME=hello_world
WHATSAPP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_ALLOWED_TEMPLATES=hello_world:en_US
WHATSAPP_TIMEOUT_MS=8000
